# Normalize line endings across Windows + macOS.
# Default: LF. Shell scripts MUST be LF or they break on macOS (`bash\r`).
* text=auto eol=lf

# Windows-native scripts keep CRLF.
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.ahk  text eol=crlf

# Binary
*.png binary
*.jpg binary
*.ico binary
