// 8 Claude agents, 2x4 grid (2 columns, 4 rows each).
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        children
        pane size=2 borderless=true { plugin location="zellij:status-bar"; }
    }
    tab name="agents" {
        pane split_direction="vertical" {
            pane split_direction="horizontal" { pane command="claude"; pane command="claude"; pane command="claude"; pane command="claude"; }
            pane split_direction="horizontal" { pane command="claude"; pane command="claude"; pane command="claude"; pane command="claude"; }
        }
    }
}
