// 5 Claude agents - column-heavy: 3 columns on top, 2 on the bottom.
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        children
    }
    tab name="agents" {
        pane split_direction="horizontal" {
            pane size=1 borderless=true command="node" {
                args "{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/claude-cc/agentbar.mjs"
            }
            pane split_direction="horizontal" {
                pane split_direction="vertical" { pane command="claude"; pane command="claude"; pane command="claude"; }
                pane split_direction="vertical" { pane command="claude"; pane command="claude"; }
            }
        }
    }
}
