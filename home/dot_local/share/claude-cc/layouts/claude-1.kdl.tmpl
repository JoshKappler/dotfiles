// 1 Claude agent (full window).
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        children
    }
    tab name="agents" {
        // Shortcut bar on top (kept in the tab content so it always shows), agent below.
        pane split_direction="horizontal" {
            pane size=1 borderless=true command="node" {
                args "{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/claude-cc/agentbar.mjs"
            }
            pane command="claude"
        }
    }
}
