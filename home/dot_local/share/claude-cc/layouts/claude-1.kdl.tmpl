// 1 Claude agent. Opened by Home via: zellij action new-tab --layout claude-1.kdl
layout {
    default_tab_template {
        // Row 1: tabs (which window you're on). Row 2: the shortcut guide.
        pane size=1 borderless=true { plugin location="zellij:compact-bar"; }
        pane size=1 borderless=true command="node" {
            args "{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/claude-cc/agentbar.mjs"
        }
        children
    }
    tab name="agents" {
        pane command="claude"
    }
}
