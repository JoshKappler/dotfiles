// 7 Claude agents, 2 columns (left 4 rows, right 3 rows).
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:compact-bar"; }
        pane size=1 borderless=true command="node" {
            args "{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/claude-cc/agentbar.mjs"
        }
        children
    }
    tab name="agents" {
        pane split_direction="vertical" {
            pane split_direction="horizontal" { pane command="claude"; pane command="claude"; pane command="claude"; pane command="claude"; }
            pane split_direction="horizontal" { pane command="claude"; pane command="claude"; pane command="claude"; }
        }
    }
}
