// 3 Claude agents, stacked rows.
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        children
        pane size=2 borderless=true { plugin location="zellij:status-bar"; }
    }
    tab name="agents" {
        pane split_direction="horizontal" {
            pane command="claude"
            pane command="claude"
            pane command="claude"
        }
    }
}
