// 1 Claude agent. Opened by Home via: zellij action new-tab --layout claude-1.kdl
layout {
    default_tab_template {
        // One clean top bar: tabs + a compact mode indicator. The old two-line
        // status-bar (Ctrl/Alt keybind tiles + "ALT-click group" mouse hints)
        // is gone; every key is documented on the Home tab's footer instead.
        pane size=1 borderless=true { plugin location="zellij:compact-bar"; }
        children
    }
    tab name="agents" {
        pane command="claude"
    }
}
