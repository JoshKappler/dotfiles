{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "node ~/.local/share/claude-cc/statusline.mjs"
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "node ~/.local/share/claude-cc/hooks/session-register.mjs" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "node ~/.local/share/claude-cc/hooks/session-register.mjs" } ] }
    ],
    "SubagentStart": [
      { "hooks": [ { "type": "command", "command": "node ~/.local/share/claude-cc/hooks/subagent-track.mjs" } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "node ~/.local/share/claude-cc/hooks/subagent-track.mjs" } ] }
    ],
    "TaskCreated": [
      { "hooks": [ { "type": "command", "command": "node ~/.local/share/claude-cc/hooks/subagent-track.mjs" } ] }
    ],
    "TaskCompleted": [
      { "hooks": [ { "type": "command", "command": "node ~/.local/share/claude-cc/hooks/subagent-track.mjs" } ] }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true,
  "agentPushNotifEnabled": false
}
