// 2x2 grid of Claude Code sessions. Launch: zellij --layout claude-grid
layout {
    tab name="claude" {
        pane split_direction="vertical" {
            pane split_direction="horizontal" { pane command="claude"; pane command="claude"; }
            pane split_direction="horizontal" { pane command="claude"; pane command="claude"; }
        }
    }
}
