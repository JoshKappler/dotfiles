// cc-default — the control-center session layout (Tab 0 = Home, the Node TUI).
// Lives in the zellij layout dir so `default_layout "cc-default"` resolves it by
// name; the launcher creates the session via `zellij attach -c claude-cc`.
layout {
    default_tab_template {
        // One clean top bar: tabs + a compact mode indicator. The old two-line
        // status-bar (Ctrl/Alt keybind tiles + "ALT-click group" mouse hints)
        // is gone; every key is documented on the Home tab's footer instead.
        pane size=1 borderless=true { plugin location="zellij:compact-bar"; }
        children
    }
    tab name="Home" focus=true {
        pane command="node" {
            args "{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/claude-cc/home.mjs"
        }
    }
}
