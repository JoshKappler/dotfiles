// cc-default — the control-center session layout (Tab 0 = Home, the Node TUI).
// Lives in the zellij layout dir so `default_layout "cc-default"` resolves it by
// name; the launcher creates the session via `zellij attach -c claude-cc`.
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        children
        pane size=2 borderless=true { plugin location="zellij:status-bar"; }
    }
    tab name="Home" focus=true {
        pane command="node" {
            args "{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/claude-cc/home.mjs"
        }
    }
}
